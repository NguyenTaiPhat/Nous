-- Lighting
pcall(function()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 100000
    Lighting.Brightness = 1.8
    Lighting.Ambient = Color3.new(1,1,1)
    Lighting.OutdoorAmbient = Color3.new(1,1,1)
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    local sky = Lighting:FindFirstChildWhichIsA("Sky")
    if sky then sky:Destroy() end
end)

-- Optimize toàn bộ Workspace
for _, obj in Workspace:GetDescendants() do
    if obj:IsA("BasePart") then
        cleanVisuals(obj)
    elseif table.find(DESTROY_CLASSES, obj.ClassName) then
        obj:Destroy()
    elseif isHumanoidModel(obj) then
        task.defer(minimalCleanCharacter, obj)
    end
end

Workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("BasePart") then
        cleanVisuals(obj)
    elseif table.find(DESTROY_CLASSES, obj.ClassName) then
        obj:Destroy()
    elseif isHumanoidModel(obj) then
        task.delay(0.20, minimalCleanCharacter, obj)
    end
end)

-- Character handling
local function onCharacterAdded(char)
    task.delay(0.35, minimalCleanCharacter, char)
end

if lp.Character then task.delay(0.4, minimalCleanCharacter, lp.Character) end
lp.CharacterAdded:Connect(onCharacterAdded)

for _, p in Players:GetPlayers() do
    if p ~= lp and p.Character then
        task.delay(0.4, minimalCleanCharacter, p.Character)
    end
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c) task.delay(0.35, minimalCleanCharacter, c) end)
end)

-- Khởi tạo GUI premium
createPremiumStatusLabel()

