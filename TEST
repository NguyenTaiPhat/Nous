--  World & Character Optimization (giữ nguyên tối ưu)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function isImportantSystemFolder(obj)
    if not obj:IsA("Folder") then return false end
    local name = obj.Name
    for _, avoid in AVOID_FOLDERS do
        if name:find(avoid, 1, true) then return true end
    end
    return false
end

local function shouldOptimizePart(part)
    if part:IsDescendantOf(lp.Character) then return false end
    if part.Parent and isImportantSystemFolder(part.Parent) then return false end
    return true
end

local function optimizePart(part)
    if not shouldOptimizePart(part) then return end
    part.Material = Enum.Material.SmoothPlastic
    part.Color = STONE_COLOR
    part.CastShadow = false
    part.Reflectance = 0
    part.Transparency = HIDE_ALPHA
end

local function cleanVisuals(obj)
    if table.find(DESTROY_CLASSES, obj.ClassName) then
        obj:Destroy()
        return
    end
    if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("Part") then
        optimizePart(obj)
    end
end

local function isHumanoidModel(model)
    return model:IsA("Model") and model:FindFirstChildWhichIsA("Humanoid", true)
end

local function minimalCleanCharacter(model)
    if not model or not model.Parent then return end
    for _, v in model:GetDescendants() do
        if (v:IsA("BasePart") or v:IsA("MeshPart")) and v.Name ~= "HumanoidRootPart" and v.Name ~= "Head" then
            v.Transparency = HIDE_ALPHA
            v.Material = Enum.Material.SmoothPlastic
            v.Color = STONE_COLOR
            v.CastShadow = false
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("SpecialMesh") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("Accessory") or v:IsA("Hat") or v:IsA("BodyColors") then
            v:Destroy()
        end
    end
end

