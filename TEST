local Lighting       = game:GetService("Lighting")
local Players        = game:GetService("Players")
local RunService     = game:GetService("RunService")
local TweenService   = game:GetService("TweenService")
local Workspace      = game:GetService("Workspace")
local lp             = Players.LocalPlayer

local STONE_COLOR    = Color3.fromRGB(108, 108, 108)
local HIDE_ALPHA     = 1

local DESTROY_CLASSES = {
    "Decal", "Texture", "SurfaceAppearance", "ParticleEmitter", "Trail", "Beam",
    "Fire", "Smoke", "Sparkles", "BloomEffect", "BlurEffect", "ColorCorrectionEffect",
    "DepthOfFieldEffect", "SunRaysEffect", "PointLight", "SurfaceLight", "SpotLight",
    "Explosion", "Highlight"
}

local AVOID_FOLDERS = {"Camera", "Terrain", "NPC", "Units", "Mobs"}

